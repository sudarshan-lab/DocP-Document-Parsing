{
  "buildCommand": "CI=false react-scripts build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://ec2-18-218-244-81.us-east-2.compute.amazonaws.com:9000/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
