# backend/.env.example — copy to backend/.env and fill in real values.
# (backend/.gitignore ignores .env, so real secrets stay out of git.)

# Port the Express server listens on (serves the built UI + /api). Defaults to 9000.
PORT=9000

# MongoDB connection string. Local dev default shown; for prod use your Atlas URI.
MONGO_URI=mongodb://127.0.0.1:27017/docp

# Anthropic (Claude) — used by extract_results() to turn extracted text into JSON.
# REQUIRED for the server to start (the Claude client is constructed at startup
# and throws if unset) and for every document upload. Key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# AWS — Textract + S3. On EC2, prefer an IAM instance role and leave the 4 key
# lines blank (the SDK falls back to the role). Region MUST match your bucket's.
# TEXTRACT_BUCKET_NAME stages the PDF for Textract; defaults to AWS_BUCKET_NAME
# when unset, so a single bucket can serve both.
TEXTRACT_ACCESS_KEY=
TEXTRACT_SECRET_ACCESS_KEY=
TEXTRACT_REGION=us-east-2
TEXTRACT_BUCKET_NAME=

# S3 bucket where uploaded files are stored (S3Upload() in app.js).
AWS_ACCESS_KEY=
AWS_ACCESS_SECRETKEY=
AWS_REGION=us-east-2
AWS_BUCKET_NAME=your-upload-bucket

# NOTE: connection.js reads MONGO_URI from here, falling back to a local
# MongoDB (mongodb://127.0.0.1:27017/docp) when it is unset.
